# ─────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────
# VISA_CTRL — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Admin panel password — only you know this
ADMIN_PASSWORD=your-strong-password-here

# ── Email Notifications (SMTP) ────────────────────────────────
# For Gmail: enable 2FA and create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=your-app-password-here

# ── Email Notifications (Resend) ─────────────────────────────
# Optional - Resend API for email notifications
# Get API key at https://resend.com
RESEND_API_KEY=re_123456789

# ── Telegram Notifications ───────────────────────────────────
# Optional - Telegram bot for instant notifications
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ── Flask ─────────────────────────────────────────────────────
# Set to "true" ONLY in local development
FLASK_DEBUG=false
PORT=5000
